// text_logger.tjs
// KiriKiri 2 / old TJS-safe logger.
// No TextWriteStream.
// No closures.
// Logs to savedata/krkr.console.log through Debug.message.
//
// Load from startup.tjs:
//   Scripts.execStorage("text_logger.tjs");

var __TEXT_LOGGER_SHOW_POPUP = true;
var __TEXT_LOGGER_INSTALLED = false;

// ------------------------------------------------------------
// Basic helpers
// ------------------------------------------------------------



var __tl_text_buffer = "";
var __tl_current_character = "";
var __tl_last_character = "";
var __tl_current_character_fresh = false;

function __tl_shell_quote(s)
{
    s = __tl_to_string(s);

    // Basic Windows command-line quoting.
    s = s.replace(/\\/g, "\\\\");
    s = s.replace(/"/g, "\\\"");

    return "\"" + s + "\"";
}

function __tl_set_character(name)
{
    name = __tl_trim(name);

    if (name == "")
        return;

    __tl_current_character = name;
    __tl_current_character_fresh = true;
    Debug.message("[text_logger][character] " + __tl_current_character);
}

function __tl_get_character_arg()
{
    var c = __tl_trim(__tl_current_character);

    if (c == "")
        return "";

    return "-c " + __tl_shell_quote(c) + " ";
}

function __tl_set_current_character_silent(name)
{
    name = __tl_trim(name);

    if (name == "")
        return false;

    __tl_current_character = name;
    __tl_last_character = name;
    __tl_current_character_fresh = true;
    return true;
}

function __tl_clear_stale_character()
{
    if (__tl_current_character_fresh)
        return;

    __tl_current_character = "";
}

function __tl_starts_with(s, prefix)
{
    s = __tl_to_string(s);
    prefix = __tl_to_string(prefix);

    if (prefix == "")
        return true;

    return s.indexOf(prefix) == 0;
}

function __tl_ends_with(s, suffix)
{
    s = __tl_to_string(s);
    suffix = __tl_to_string(suffix);

    if (suffix == "")
        return true;

    if (s.length < suffix.length)
        return false;

    return s.substring(s.length - suffix.length, s.length) == suffix;
}

function __tl_strip_trailing_speaker_name(text, speaker)
{
    text = __tl_trim(text);
    speaker = __tl_trim(speaker);

    if (speaker == "")
        return text;

    if (!__tl_ends_with(text, speaker))
        return text;

    var withoutSpeaker = __tl_trim(text.substring(0, text.length - speaker.length));

    if (__tl_ends_with(withoutSpeaker, "」"))
        return withoutSpeaker;

    return text;
}

function __tl_strip_speaker_artifacts(text, speaker)
{
    text = __tl_trim(text);
    speaker = __tl_trim(speaker);

    if (speaker == "")
        return text;

    if (__tl_starts_with(text, speaker + speaker + "「"))
        text = text.substring((speaker + speaker).length, text.length);
    else if (__tl_starts_with(text, speaker + "「"))
        text = text.substring(speaker.length, text.length);

    while (__tl_starts_with(text, "「「"))
        text = "「" + text.substring(2, text.length);

    text = __tl_strip_trailing_speaker_name(text, speaker);

    return __tl_trim(text);
}

function __tl_strip_leading_noise(text)
{
    text = __tl_trim(text);

    var changed = true;
    while (changed)
    {
        changed = false;

        while (__tl_starts_with(text, "\\n"))
        {
            text = __tl_trim(text.substring(2, text.length));
            changed = true;
        }

        if (__tl_starts_with(text, "(未設定)"))
        {
            text = __tl_trim(text.substring(4, text.length));
            changed = true;
        }
    }

    return text;
}

function __tl_is_unknown_speaker_prefix(prefix)
{
    prefix = __tl_trim(prefix);

    if (prefix == "")
        return false;

    var i;
    for (i = 0; i < prefix.length; i++)
    {
        var ch = prefix.substring(i, i + 1);
        if (ch != "？" && ch != "?")
            return false;
    }

    return true;
}

function __tl_try_infer_speaker_from_repeated_prefix(text)
{
    text = __tl_trim(text);

    var idx = text.indexOf("「");
    if (idx <= 0)
        return false;

    var prefix = __tl_trim(text.substring(0, idx));
    if (__tl_is_unknown_speaker_prefix(prefix))
    {
        __tl_set_current_character_silent(prefix);
        return true;
    }

    if (prefix == "" || (prefix.length % 2) != 0)
        return false;

    var half = prefix.length / 2;
    var first = prefix.substring(0, half);
    var second = prefix.substring(half, prefix.length);

    if (first == "" || first != second)
        return false;

    __tl_set_current_character_silent(first);
    return true;
}

function __tl_normalize_dialogue_text(text)
{
    text = __tl_trim(text);
    text = __tl_strip_leading_noise(text);

    // Inline speaker prefixes should override stale speaker state from the
    // previous line.
    if (!__tl_try_infer_speaker_from_repeated_prefix(text))
        __tl_clear_stale_character();

    if (__tl_trim(__tl_current_character) != "")
        text = __tl_strip_speaker_artifacts(text, __tl_current_character);

    return text;
}

function appendTextLog(text)
{
    text = __tl_to_string(text);

    if (__tl_trim(text) == "")
        return true;

    // log.exe should be built with:
    // GOOS=windows GOARCH=386 go build -ldflags="-H=windowsgui" -o log.exe main.go
    //
    // If a character is known:
    //   log.exe -c "Character Name" "dialog text"
    //
    // If no character is known:
    //   log.exe "dialog text"

    var args = __tl_get_character_arg() + __tl_shell_quote(text);
    var ok = System.shellExecute("log.exe", args);

    return ok;
}



function __tl_maybe_set_character_from_params(kind, params)
{
    if (params === void)
        return false;

    var name = "";

    try
    {
        if (params["text"] !== void) name = params["text"];
        else if (params["name"] !== void) name = params["name"];
        else if (params["chara"] !== void) name = params["chara"];
        else if (params["character"] !== void) name = params["character"];
        else if (params["speaker"] !== void) name = params["speaker"];
        else if (params["caption"] !== void) name = params["caption"];
        else if (params["label"] !== void) name = params["label"];
        else if (params["who"] !== void) name = params["who"];
        else if (params["actor"] !== void) name = params["actor"];
    }
    catch (e)
    {
        return false;
    }

    name = __tl_trim(name);

    if (name == "")
        return false;

    // Avoid obvious non-speaker values.
    if (name.indexOf("*") == 0) return false;
    if (name.indexOf("storage") >= 0) return false;
    if (name.indexOf(".ks") >= 0) return false;
    if (name.indexOf(".tjs") >= 0) return false;
    if (name.indexOf("/") >= 0) return false;
    if (name.indexOf("\\") >= 0) return false;

    __tl_current_character = name;
    __tl_last_character = name;
    __tl_current_character_fresh = true;

    Debug.message("[text_logger][speaker." + kind + "] " + name);
    return true;
}

function __tl_wrap_name(params)
{
    try { __tl_maybe_set_character_from_params("name", params); }
    catch (e) { Debug.message("[text_logger] name speaker failed"); }

    return __tl_call_original("name", params);
}

function __tl_wrap_nm(params)
{
    try { __tl_maybe_set_character_from_params("nm", params); }
    catch (e) { Debug.message("[text_logger] nm speaker failed"); }

    return __tl_call_original("nm", params);
}

function __tl_wrap_chara(params)
{
    try { __tl_maybe_set_character_from_params("chara", params); }
    catch (e) { Debug.message("[text_logger] chara speaker failed"); }

    return __tl_call_original("chara", params);
}

function __tl_wrap_speaker(params)
{
    try { __tl_maybe_set_character_from_params("speaker", params); }
    catch (e) { Debug.message("[text_logger] speaker failed"); }

    return __tl_call_original("speaker", params);
}

function __tl_wrap_talk(params)
{
    try { __tl_maybe_set_character_from_params("talk", params); }
    catch (e) { Debug.message("[text_logger] talk speaker failed"); }

    return __tl_call_original("talk", params);
}

function __tl_is_probably_text(s)
{
    s = __tl_to_string(s);

    if (__tl_trim(s) == "")
        return false;

    // Ignore object dumps / noisy internals.
    if (s.indexOf("(object ") == 0)
        return false;

    // Ignore obvious script/control expressions.
    if (s.indexOf("f.") == 0) return false;
    if (s.indexOf("sf.") == 0) return false;
    if (s.indexOf("tf.") == 0) return false;
    if (s.indexOf("mp.") == 0) return false;
    if (s.indexOf("kag.") >= 0) return false;

    return true;
}

function __tl_add_text(s)
{
    s = __tl_clean(s);

    if (!__tl_is_probably_text(s))
        return;

    __tl_text_buffer += s;
}

function __tl_flush_text(reason)
{
    var text = __tl_normalize_dialogue_text(__tl_text_buffer);
    __tl_text_buffer = "";

    if (text == "")
        return;

    Debug.message("[text_logger][line." + reason + "] " + text);

    try
    {
        // Raw text only: no [text_logger], no kind, no translation.
        appendTextLog(text);
        __tl_current_character_fresh = false;
    }
    catch (e)
    {
        Debug.message("[text_logger] appendTextLog failed: " + e.message);
    }
}


function __tl_to_string(v)
{
    if (v === void) return "";
    return "" + v;
}

function __tl_trim(s)
{
    s = __tl_to_string(s);
    s = s.replace(/^\s+/, "");
    s = s.replace(/\s+$/, "");
    return s;
}

function __tl_clean(s)
{
    s = __tl_to_string(s);
    s = s.replace(/\r/g, "");
    s = s.replace(/\n/g, "\\n");
    return s;
}

var __TEXT_LOGGER_COUNT = 0;

function __tl_log(kind, text)
{
    text = __tl_clean(text);

    if (__tl_trim(text) == "")
        return;

    var line = "[text_logger][" + kind + "] " + text;

    Debug.message(line);

    try
    {
        appendTextLog(line);
    }
    catch (e)
    {
        Debug.message("[text_logger] appendTextLog failed: " + e.message);
    }
}

// ------------------------------------------------------------
// Param logging
// ------------------------------------------------------------

function __tl_log_key(kind, params, key)
{
    try
    {
        if (params[key] !== void)
        {
            __tl_log(kind + "." + key, params[key]);
            return true;
        }
    }
    catch (e)
    {
    }

    return false;
}

function __tl_log_params(kind, params)
{
    if (params === void)
    {
        __tl_log(kind, "(params void)");
        return;
    }

    var found = false;

    // Common KAG params.
    if (__tl_log_key(kind, params, "text")) found = true;
    if (__tl_log_key(kind, params, "ch")) found = true;
    if (__tl_log_key(kind, params, "caption")) found = true;
    if (__tl_log_key(kind, params, "label")) found = true;
    if (__tl_log_key(kind, params, "name")) found = true;
    if (__tl_log_key(kind, params, "value")) found = true;
    if (__tl_log_key(kind, params, "hint")) found = true;
    if (__tl_log_key(kind, params, "message")) found = true;
    if (__tl_log_key(kind, params, "str")) found = true;
    if (__tl_log_key(kind, params, "exp")) found = true;
    if (__tl_log_key(kind, params, "title")) found = true;
    if (__tl_log_key(kind, params, "target")) found = true;
    if (__tl_log_key(kind, params, "storage")) found = true;
    if (__tl_log_key(kind, params, "layer")) found = true;
    if (__tl_log_key(kind, params, "page")) found = true;
    if (__tl_log_key(kind, params, "time")) found = true;

    // Always try a raw-ish dump too.
    // Some old TJS objects stringify badly, so this is guarded.
    try
    {
        __tl_log(kind + ".params", params);
    }
    catch (e)
    {
    }

    if (!found)
    {
        __tl_log(kind, "(no known params)");
    }
}

// ------------------------------------------------------------
// Original caller
// ------------------------------------------------------------

function __tl_call_original(tagName, params)
{
    return kag.tagHandlers["__text_logger_original_" + tagName](params);
}

// ------------------------------------------------------------
// Explicit wrappers
// Do NOT use closures here. Old TJS loses captured vars.
// ------------------------------------------------------------


function __tl_wrap_ch(params)
{
    try
    {
        if (params !== void && params["text"] !== void)
            __tl_add_text(params["text"]);
        else if (params !== void && params["ch"] !== void)
            __tl_add_text(params["ch"]);
    }
    catch (e)
    {
        Debug.message("[text_logger] ch log failed");
    }

    return __tl_call_original("ch", params);
}

function __tl_wrap_r(params)
{
    try
    {
        // Line break inside same message.
        __tl_add_text("\n");
    }
    catch (e)
    {
        Debug.message("[text_logger] r log failed");
    }

    return __tl_call_original("r", params);
}

function __tl_wrap_l(params)
{
    try
    {
        // Usually click-wait / line break. Flush current line.
        __tl_flush_text("l");
    }
    catch (e)
    {
        Debug.message("[text_logger] l log failed");
    }

    return __tl_call_original("l", params);
}

function __tl_wrap_p(params)
{
    try
    {
        // Page break / end of message. Flush current line.
        __tl_flush_text("p");
    }
    catch (e)
    {
        Debug.message("[text_logger] p log failed");
    }

    return __tl_call_original("p", params);
}

function __tl_wrap_er(params)
{
    try { __tl_log_params("er", params); } catch (e) { Debug.message("[text_logger] er log failed"); }
    return __tl_call_original("er", params);
}

function __tl_wrap_cm(params)
{
    try { __tl_log_params("cm", params); } catch (e) { Debug.message("[text_logger] cm log failed"); }
    return __tl_call_original("cm", params);
}

