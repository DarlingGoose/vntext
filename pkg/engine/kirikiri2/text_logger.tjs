// ------------------------------------------------------------
// Install helpers
// ------------------------------------------------------------

function __tl_install_tag(tagName, wrapper)
{
    if (kag === void) return false;
    if (kag.tagHandlers === void) return false;
    if (kag.tagHandlers[tagName] === void) return false;

    var hooked = "__text_logger_hooked_" + tagName;
    var original = "__text_logger_original_" + tagName;

    try
    {
        if (kag.tagHandlers[hooked])
            return true;
    }
    catch (e)
    {
    }

    kag.tagHandlers[original] = kag.tagHandlers[tagName];
    kag.tagHandlers[tagName] = wrapper;
    kag.tagHandlers[hooked] = true;

    Debug.message("[text_logger] hooked " + tagName);
    return true;
}

function __tl_try_hook_taghandlers()
{
    if (kag === void) return false;
    if (kag.tagHandlers === void) return false;

    __tl_install_tag("ch", __tl_wrap_ch);
    __tl_install_tag("r", __tl_wrap_r);
    __tl_install_tag("l", __tl_wrap_l);
    __tl_install_tag("p", __tl_wrap_p);

    // Common speaker/name tags.
    __tl_install_tag("name", __tl_wrap_name);
    __tl_install_tag("nm", __tl_wrap_nm);
    __tl_install_tag("chara", __tl_wrap_chara);
    __tl_install_tag("speaker", __tl_wrap_speaker);
    __tl_install_tag("talk", __tl_wrap_talk);

    // Choice/menu tags. Many KAG games render Japanese route choices and
    // command menus through these instead of plain ch/l/p dialogue tags.
    //__tl_install_tag("button", __tl_wrap_button);
    //__tl_install_tag("link", __tl_wrap_link);
    //__tl_install_tag("glink", __tl_wrap_glink);
    __tl_install_tag("select", __tl_wrap_select);
    __tl_install_tag("seladd", __tl_wrap_seladd);
    __tl_install_tag("selopt", __tl_wrap_selopt);
    __tl_install_tag("mselect", __tl_wrap_mselect);
    __tl_install_tag("mseladd", __tl_wrap_mseladd);
    __tl_install_tag("mselopt", __tl_wrap_mselopt);
    __tl_install_tag("checkbox", __tl_wrap_checkbox);
    __tl_install_tag("edit", __tl_wrap_edit);

    return true;
}

function __tl_install()
{
    if (__TEXT_LOGGER_INSTALLED)
        return true;

    if (!__tl_try_hook_taghandlers())
        return false;

    __TEXT_LOGGER_INSTALLED = true;

    Debug.message("[text_logger] installed");
    //__tl_log("system", "text_logger installed");

    return true;
}

// ------------------------------------------------------------
// Startup
// ------------------------------------------------------------

if (__TEXT_LOGGER_SHOW_POPUP)
{
    System.inform("text_logger loaded");
}

if (!__tl_install())
{
    Debug.message("[text_logger] waiting for kag.tagHandlers...");

    var __tl_timer = new Timer();
    __tl_timer.interval = 100;

    __tl_timer.onTimer = function()
    {
        if (__tl_install())
        {
            __tl_timer.enabled = false;
            Debug.message("[text_logger] timer stopped");
        }
    };

    __tl_timer.enabled = true;
}
